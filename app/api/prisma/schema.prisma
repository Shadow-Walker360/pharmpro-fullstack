// ============================================================
// PharmPro Enterprise
// Prisma Schema
// Database: PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  PHARMACIST
  DOCTOR
  CASHIER
  STORE_MANAGER
  LAB_TECHNICIAN
  ACCOUNTANT
  RECEPTIONIST
}

enum UserStatus {
  ACTIVE
  PENDING
  SUSPENDED
  LOCKED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PaymentMethod {
  CASH
  MPESA
  CARD
  BANK_TRANSFER
  INSURANCE
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  TRANSFER
  EXPIRED
  DAMAGED
}

enum PrescriptionStatus {
  DRAFT
  PENDING
  DISPENSING
  COMPLETED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  PRINT
}

enum ClaimStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
  PAID
  APPEALED
  CANCELLED
}

enum PreAuthStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  DENIED
}

enum ClaimantRelationship {
  SELF
  SPOUSE
  CHILD
  DEPENDENT
}

enum PaymentMethod {
  CASH
  MPESA
  CARD
 BANK_TRANSFER
  INSURANCE
}

enum SaleStatus {
  COMPLETED
  REFUNDED
  CANCELLED
}

enum PrescriptionStatus {
  PENDING
  VERIFIED
  DISPENSING
  COMPLETED
  CANCELLED
}
enum ClaimPriority {
  NORMAL
  URGENT
}
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
}
enum UserRole {
  SUPER_ADMIN
  ADMIN
  PHARMACIST
  DOCTOR
  CASHIER
  STORE_MANAGER
  ACCOUNTANT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE

  B_POSITIVE
  B_NEGATIVE

  AB_POSITIVE
  AB_NEGATIVE

  O_POSITIVE
  O_NEGATIVE
}

enum DrugCategory {
  ANALGESIC

  ANTIBIOTIC

  ANTIFUNGAL

  ANTIVIRAL

  ANTIHISTAMINE

  ANTIHYPERTENSIVE

  ANTIDIABETIC

  VITAMIN

  VACCINE

  SUPPLEMENT

  OTHER
}

enum DosageForm {
  TABLET

  CAPSULE

  SYRUP

  SUSPENSION

  INJECTION

  CREAM

  OINTMENT

  DROPS

  INHALER

  POWDER

  GEL

  PATCH

  OTHER
}

enum InventoryMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
  TRANSFER
  EXPIRED
  DAMAGED
}

enum PurchaseStatus {
  PENDING
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PrescriptionStatus {
  PENDING
  VERIFIED
  DISPENSING
  DISPENSED
  CANCELLED
}

enum PrescriptionPriority {
  LOW
  NORMAL
  HIGH
  EMERGENCY
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum SaleType {
  CASH
  MPESA
  CARD
  INSURANCE
  CREDIT
}

// ============================================================
// CORE MODELS
// ============================================================

model Branch {
  id        String   @id @default(cuid())

  name      String
  code      String   @unique

  phone     String?
  email     String?
  address   String?

  prescriptions Prescription[]
  sales Sale[]

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // ───────── Relationships ─────────

  users             User[]
  patients          Patient[]
  drugs             Drug[]
  inventoryItems    InventoryItem[]
  purchases         Purchase[]
  prescriptions     Prescription[]
  sales             Sale[]

  insurancePayers   InsurancePayer[]
  insuranceClaims   InsuranceClaim[]
}


model User {
  id            String   @id @default(cuid())

  firstName     String
  lastName      String

  email         String   @unique
  phone         String?

  passwordHash  String

  role          UserRole

  isActive      Boolean  @default(true)

  lastLoginAt   DateTime?

  doctorPrescriptions     Prescription[] @relation("DoctorPrescriptions")

  pharmacistPrescriptions Prescription[] @relation("PharmacistPrescriptions")
  sales Sale[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  // ───────── Branch ─────────

  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id])

  // ───────── Insurance ─────────

  claimsCreated       InsuranceClaim[]     @relation("ClaimCreatedBy")
  claimStatusChanges  ClaimStatusHistory[] @relation("ClaimStatusChangedBy")
}

model Patient {
  id                 String   @id @default(cuid())

  // ───────── Basic Information ─────────

  firstName          String
  lastName           String

  dateOfBirth        DateTime
  gender             Gender

  nationalId         String?  @unique

  phone              String?
  email              String?

  address            String?

  // ───────── Medical Information ─────────

  bloodGroup         BloodGroup?
  allergies          String?
  chronicConditions  String?

  emergencyContactName   String?
  emergencyContactPhone  String?

  // ───────── Branch ─────────

  branchId           String
  branch             Branch   @relation(fields: [branchId], references: [id])

  // ───────── Insurance ─────────

  insuranceClaims    InsuranceClaim[]

  // ───────── Audit ─────────

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  @@index([branchId])
  @@index([lastName])
}


model Branch {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique

  phone       String?
  email       String?

  address     String?
  city        String?
  county      String?

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // ==========================
  // Relations
  // ==========================

  users             User[]

  patients          Patient[]

  drugs             Drug[]

  prescriptions     Prescription[]

  sales             Sale[]

  purchaseOrders    PurchaseOrder[]

  insurancePayers   InsurancePayer[]

  insuranceClaims   InsuranceClaim[]

  expenses          Expense[]

  auditLogs         AuditLog[]

  @@index([code])
}

model User {
  id              String      @id @default(cuid())

  firstName       String
  lastName        String

  email           String      @unique

  passwordHash    String

  phone           String?

  role            UserRole

  status          UserStatus  @default(ACTIVE)

  branchId        String
  branch          Branch       @relation(fields: [branchId], references: [id])

  refreshTokens   RefreshToken[]

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  // ==========================
  // Relations (filled later)
  // ==========================

  claimsCreated        InsuranceClaim[]     @relation("ClaimCreatedBy")

  claimStatusChanges   ClaimStatusHistory[] @relation("ClaimStatusChangedBy")

  auditLogs            AuditLog[]
}

model RefreshToken {
  id          String   @id @default(cuid())

  token       String   @unique

  expiresAt   DateTime

  revoked     Boolean  @default(false)

  userId      String

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id          String      @id @default(cuid())

  action      AuditAction

  tableName   String

  recordId    String

  description String?

  ipAddress   String?

  userAgent   String?

  userId      String?

  user        User?       @relation(fields: [userId], references: [id])

  branchId    String?

  branch      Branch?     @relation(fields: [branchId], references: [id])

  createdAt   DateTime    @default(now())

  @@index([tableName])

  @@index([recordId])

  @@index([createdAt])
}


// ============================================================
// PATIENTS
// ============================================================

model Patient {
  id                String      @id @default(cuid())

  patientNumber     String      @unique

  firstName         String
  lastName          String

  gender            Gender

  dateOfBirth       DateTime?

  nationalId        String?

  phone             String?

  email             String?

  address           String?

  city              String?

  emergencyContact  String?

  emergencyPhone    String?

  bloodGroup        String?

  height            Float?

  weight            Float?

  isActive          Boolean     @default(true)

  branchId          String
  branch            Branch      @relation(fields: [branchId], references: [id])
  sales Sale[]

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?

  prescriptions Prescription[]

  // ==========================
  // Relations
  // ==========================

  allergies         PatientAllergy[]
  conditions        PatientCondition[]
  visits            PatientVisit[]
  prescriptions     Prescription[]
  sales             Sale[]

  insuranceClaims   InsuranceClaim[]

  @@index([branchId])
  @@index([lastName])
  @@index([phone])
}

model PatientAllergy {
  id          String      @id @default(cuid())

  patientId   String
  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  allergy     String

  severity    String?

  notes       String?

  createdAt   DateTime    @default(now())

  @@index([patientId])
}

model PatientCondition {
  id            String      @id @default(cuid())

  patientId     String
  patient       Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  condition     String

  diagnosedOn   DateTime?

  notes         String?

  createdAt     DateTime    @default(now())

  @@index([patientId])
}

model PatientVisit {
  id              String      @id @default(cuid())

  patientId       String
  patient         Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)

  visitDate       DateTime    @default(now())

  chiefComplaint  String?

  diagnosis       String?

  notes           String?

  createdAt       DateTime    @default(now())

  @@index([patientId])
}

model Drug {
  id                    String   @id @default(cuid())

  // ───────── Identity ─────────

  name                  String
  genericName           String?

  brand                 String?

  sku                   String   @unique
  barcode               String?  @unique

  // ───────── Classification ─────────

  category              DrugCategory

  dosageForm            DosageForm

  strength              String

  manufacturer          String?

  requiresPrescription  Boolean @default(false)

  // ───────── Pricing ─────────

  costPrice             Decimal @db.Decimal(10,2)

  sellingPrice          Decimal @db.Decimal(10,2)

  taxRate               Decimal @default(0) @db.Decimal(5,2)

  // ───────── Branch ─────────

  branchId              String
  branch                Branch @relation(fields: [branchId], references: [id])

  // ───────── Insurance ─────────

  claimItems            ClaimItem[]

  // ───────── Audit ─────────

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  deletedAt             DateTime?

  @@unique([branchId, sku])
  @@index([branchId])
  @@index([name])
}


// ============================================================
// INVENTORY
// ============================================================

model DrugCategory {
  id          String   @id @default(cuid())

  name        String   @unique

  description String?

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  drugs       Drug[]
}

model Manufacturer {
  id          String   @id @default(cuid())

  name        String   @unique

  country     String?

  email       String?

  phone       String?

  website     String?

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  drugs       Drug[]
}

model Supplier {
  id          String   @id @default(cuid())

  name        String

  email       String?

  phone       String?

  address     String?

  city        String?

  contactPerson String?

  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model Drug {
  id                  String   @id @default(cuid())

  name                String

  genericName         String?

  brandName           String?

  strength            String?

  dosageForm          String?

  packSize            String?

  barcode             String?  @unique

  sku                 String   @unique

  description         String?

  requiresPrescription Boolean @default(false)

  minimumStock        Int      @default(0)

  reorderLevel        Int      @default(0)

  sellingPrice        Decimal  @db.Decimal(10,2)

  costPrice           Decimal  @db.Decimal(10,2)

  isActive            Boolean  @default(true)

  branchId            String
  branch              Branch   @relation(fields: [branchId], references: [id])

  categoryId          String?
  category            DrugCategory? @relation(fields: [categoryId], references: [id])

  manufacturerId      String?
  manufacturer        Manufacturer? @relation(fields: [manufacturerId], references: [id])

  createdAt           DateTime @default(now())

  updatedAt           DateTime @updatedAt

  deletedAt           DateTime?

  // =======================================
  // Relations
  // =======================================

  batches             Batch[]

  prescriptionItems   PrescriptionItem[]

  saleItems           SaleItem[]

  claimItems          ClaimItem[]

  @@index([branchId])

  @@index([name])

  @@index([sku])

  @@index([barcode])
}

model Batch {
  id              String   @id @default(cuid())

  batchNumber     String

  expiryDate      DateTime

  quantity        Int

  remainingQty    Int

  purchasePrice   Decimal @db.Decimal(10,2)

  sellingPrice    Decimal @db.Decimal(10,2)

  drugId          String

  drug            Drug @relation(fields: [drugId], references: [id], onDelete: Cascade)

  supplierId      String?

  supplier        Supplier? @relation(fields: [supplierId], references: [id])

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

  stockMovements  StockMovement[]

  @@index([drugId])

  @@index([expiryDate])

  @@unique([drugId, batchNumber])
}

model StockMovement {
  id              String   @id @default(cuid())

  type            StockMovementType

  quantity        Int

  balanceAfter    Int

  reference       String?

  notes           String?

  batchId         String

  batch           Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  createdById     String?

  createdBy       User? @relation(fields: [createdById], references: [id])

  createdAt       DateTime @default(now())

  @@index([batchId])

  @@index([type])

  @@index([createdAt])

  
}

// ============================================================
// PRESCRIPTIONS
// ============================================================

model Prescription {
  id                  String   @id @default(cuid())

  prescriptionNumber  String   @unique

  patientId           String
  patient             Patient @relation(fields: [patientId], references: [id])

  branchId            String
  branch              Branch @relation(fields: [branchId], references: [id])

  prescribedById      String
  prescribedBy        User @relation(fields: [prescribedById], references: [id])

  diagnosis           String?

  notes               String?

  status              PrescriptionStatus @default(PENDING)

  prescribedAt        DateTime @default(now())

  dispensedAt         DateTime?

  createdAt           DateTime @default(now())

  updatedAt           DateTime @updatedAt

  deletedAt           DateTime?

  // =====================
  // Relations
  // =====================

  items               PrescriptionItem[]

  attachments         Attachment[]

  sale                Sale?
  sale Sale?

  insuranceClaims     InsuranceClaim[]

  @@index([patientId])

  @@index([branchId])

  @@index([status])

  @@index([prescribedAt])
}

model PrescriptionItem {
  id              String @id @default(cuid())

  prescriptionId  String
  prescription    Prescription
                  @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  drugId          String
  drug            Drug
                  @relation(fields: [drugId], references: [id])

  dosage          String

  frequency       String

  duration        String

  quantity        Int

  dispensedQty    Int @default(0)

  instructions    String?

  createdAt       DateTime @default(now())

  @@index([prescriptionId])

  @@index([drugId])
}
model PrescriptionItem {
  id                    String @id @default(cuid())

  // ───────────────────────────────────────────────────────────
  // Prescription
  // ───────────────────────────────────────────────────────────

  prescriptionId        String
  prescription          Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  // ───────────────────────────────────────────────────────────
  // Drug
  // ───────────────────────────────────────────────────────────

  drugId                String
  drug                  Drug @relation(fields: [drugId], references: [id])

  // Snapshot
  drugName              String

  // ───────────────────────────────────────────────────────────
  // Prescription Details
  // ───────────────────────────────────────────────────────────

  dosage                String

  frequency             String

  duration              String

  instructions          String?

  quantityPrescribed    Int

  quantityDispensed     Int @default(0)

  unitPrice             Decimal? @db.Decimal(10,2)

  totalPrice            Decimal? @db.Decimal(12,2)

  // ───────────────────────────────────────────────────────────
  // Audit
  // ───────────────────────────────────────────────────────────

  createdAt             DateTime @default(now())

  updatedAt             DateTime @updatedAt

  @@index([prescriptionId])

  @@index([drugId])
}
model Attachment {
  id                String @id @default(cuid())

  prescriptionId    String

  prescription       Prescription
                     @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  fileName          String

  originalName      String

  mimeType          String

  fileSize          Int

  url               String

  uploadedById      String

  uploadedBy        User
                    @relation(fields: [uploadedById], references: [id])

  createdAt         DateTime @default(now())

  @@index([prescriptionId])
}

// ======================================================
// PATIENT
// ======================================================

model Patient {
  id              String   @id @default(cuid())

  // Basic identity
  firstName       String
  lastName        String
  gender          Gender
  dateOfBirth     DateTime

  // Contacts
  phone           String?
  email           String?

  // Government identifiers
  nationalId      String?
  passportNumber  String?

  // Medical information
  bloodGroup      BloodGroup?
  allergies       String?
  chronicIllness  String?
  notes           String?

  // Address
  county          String?
  town            String?
  address         String?

  // Multi-branch ownership
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id])

  // Relations
  prescriptions   Prescription[]
  sales           Sale[]
  insuranceClaims InsuranceClaim[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([branchId])
  @@index([phone])
  @@index([lastName])
}
// ======================================================
// DRUG
// ======================================================

model Drug {
  id                  String   @id @default(cuid())

  // Identification
  name                String
  genericName         String?
  brand               String?

  // Classification
  category            String?
  dosageForm          String?
  strength            String?

  // Codes
  sku                 String   @unique
  barcode             String?  @unique

  // Pricing
  buyingPrice         Decimal  @db.Decimal(12,2)
  sellingPrice        Decimal  @db.Decimal(12,2)

  // Stock settings
  minimumStock        Int      @default(0)
  reorderLevel        Int      @default(0)

  // Status
  prescriptionOnly    Boolean  @default(false)
  controlledDrug      Boolean  @default(false)
  active              Boolean  @default(true)

  // Ownership
  branchId            String
  branch              Branch   @relation(fields: [branchId], references: [id])

  // Relations
  inventory           Inventory[]
  prescriptionItems   PrescriptionItem[]
  saleItems           SaleItem[]
  purchaseItems       PurchaseItem[]
  claimItems          ClaimItem[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  prescriptionItems PrescriptionItem[]
  saleItems SaleItem[]

  @@index([branchId])
  @@index([name])
  @@index([genericName])
  @@index([brand])
}

model InventoryBatch {
  id                String   @id @default(cuid())

  batchNumber       String

  expiryDate        DateTime

  quantityReceived  Int

  quantityRemaining Int

  unitCost          Decimal @db.Decimal(10,2)

  // ───────── Drug ─────────

  drugId            String
  drug              Drug @relation(fields: [drugId], references: [id])

  // ───────── Branch ─────────

  branchId          String
  branch            Branch @relation(fields: [branchId], references: [id])

  // ───────── Purchase ─────────

  purchaseId        String?
  purchase          Purchase? @relation(fields: [purchaseId], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  @@index([drugId])
  @@index([expiryDate])
  @@index([branchId])
}

model Sale {
  id                    String @id @default(cuid())

  // ───────────────────────────────────────────────────────────
  // Sale Information
  // ───────────────────────────────────────────────────────────

  receiptNumber         String @unique

  status                SaleStatus @default(PENDING)

  saleType              SaleType @default(CASH)

  notes                 String?

  // ───────────────────────────────────────────────────────────
  // Patient
  // ───────────────────────────────────────────────────────────

  patientId             String?

  patient               Patient? @relation(fields: [patientId], references: [id])

  // ───────────────────────────────────────────────────────────
  // Prescription
  // ───────────────────────────────────────────────────────────

  prescriptionId        String?

  prescription          Prescription? @relation(fields: [prescriptionId], references: [id])

  // ───────────────────────────────────────────────────────────
  // Branch
  // ───────────────────────────────────────────────────────────

  branchId              String

  branch                Branch @relation(fields: [branchId], references: [id])

  // ───────────────────────────────────────────────────────────
  // Cashier
  // ───────────────────────────────────────────────────────────

  cashierId             String

  cashier               User @relation("CashierSales", fields: [cashierId], references: [id])

  // ───────────────────────────────────────────────────────────
  // Financial Summary
  // ───────────────────────────────────────────────────────────

  subtotal              Decimal @db.Decimal(12,2)

  discountAmount        Decimal @default(0) @db.Decimal(12,2)

  taxAmount             Decimal @default(0) @db.Decimal(12,2)

  totalAmount           Decimal @db.Decimal(12,2)

  amountPaid            Decimal @default(0) @db.Decimal(12,2)

  changeGiven           Decimal @default(0) @db.Decimal(12,2)

  // ───────────────────────────────────────────────────────────
  // Relationships
  // ───────────────────────────────────────────────────────────

  items                 SaleItem[]

  payments             Payment[]

  // ───────────────────────────────────────────────────────────
  // Audit
  // ───────────────────────────────────────────────────────────

  createdAt            DateTime @default(now())

  updatedAt            DateTime @updatedAt

  deletedAt            DateTime?

  @@index([receiptNumber])

  @@index([patientId])

  @@index([branchId])

  @@index([cashierId])

  @@index([createdAt])

  @@index([status])
}

// ======================================================
// INVENTORY (Batch-Level Stock)
// ======================================================

model Inventory {
  id                String   @id @default(cuid())

  // Drug
  drugId            String
  drug              Drug     @relation(fields: [drugId], references: [id])

  // Branch
  branchId          String
  branch            Branch   @relation(fields: [branchId], references: [id])

  // Batch information
  batchNumber       String
  supplierBatch     String?

  // Stock
  quantity          Int
  reservedQuantity  Int      @default(0)

  // Cost
  unitCost          Decimal  @db.Decimal(12,2)

  // Dates
  manufactureDate   DateTime?
  expiryDate        DateTime

  // Supplier reference
  purchaseItemId    String?
  purchaseItem      PurchaseItem? @relation(fields: [purchaseItemId], references: [id])

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  purchaseItemId String?

  purchaseItem PurchaseItem? @relation(fields: [purchaseItemId], references: [id])

  @@index([drugId])
  @@index([branchId])
  @@index([expiryDate])
  @@index([batchNumber])
}
//supplier//
model Supplier {
  id               String   @id @default(cuid())

  // ───────── Company Information ─────────

  name             String

  code             String   @unique

  contactPerson    String?

  email            String?

  phone            String?

  address          String?

  kraPin           String?

  licenseNumber    String?

  // ───────── Business Status ─────────

  isActive         Boolean  @default(true)

  // ───────── Branch ─────────

  branchId         String
  branch           Branch   @relation(fields: [branchId], references: [id])

  // ───────── Relationships ─────────

  purchases        Purchase[]
  

  // ───────── Audit ─────────

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@unique([branchId, code])
  @@index([branchId])
  @@index([name])
}
//purchase
model Purchase {
  id                  String   @id @default(cuid())

  // ───────────────────────────────────────────────────────────
  // Purchase Information
  // ───────────────────────────────────────────────────────────

  purchaseNumber      String   @unique
  supplierInvoiceNo   String?

  orderDate           DateTime @default(now())
  expectedDelivery    DateTime?
  receivedDate        DateTime?

  status              PurchaseStatus @default(PENDING)

  // ───────────────────────────────────────────────────────────
  // Supplier
  // ───────────────────────────────────────────────────────────

  supplierId          String
  supplier            Supplier @relation(fields: [supplierId], references: [id])

  // ───────────────────────────────────────────────────────────
  // Branch
  // ───────────────────────────────────────────────────────────

  branchId            String
  branch              Branch @relation(fields: [branchId], references: [id])

  // ───────────────────────────────────────────────────────────
  // User
  // ───────────────────────────────────────────────────────────

  createdById         String
  createdBy           User @relation(fields: [createdById], references: [id])

  // ───────────────────────────────────────────────────────────
  // Financial Summary
  // ───────────────────────────────────────────────────────────

  subtotal            Decimal @db.Decimal(12,2)

  discountAmount      Decimal @default(0) @db.Decimal(12,2)

  taxAmount           Decimal @default(0) @db.Decimal(12,2)

  shippingCost        Decimal @default(0) @db.Decimal(12,2)

  totalAmount         Decimal @db.Decimal(12,2)

  amountPaid          Decimal @default(0) @db.Decimal(12,2)

  balanceDue          Decimal @default(0) @db.Decimal(12,2)

  // ───────────────────────────────────────────────────────────
  // Extra Information
  // ───────────────────────────────────────────────────────────

  notes               String?

  // ───────────────────────────────────────────────────────────
  // Relationships
  // ───────────────────────────────────────────────────────────

  items               PurchaseItem[]
  saleItems SaleItem[]
  // ───────────────────────────────────────────────────────────
  // Audit
  // ───────────────────────────────────────────────────────────

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  @@index([purchaseNumber])
  @@index([supplierId])
  @@index([branchId])
  @@index([status])
  @@index([orderDate])
}
