  unitPrice       Decimal @db.Decimal(12,2)

  totalPrice      Decimal @db.Decimal(12,2)

  createdAt       DateTime @default(now())

  @@index([saleId])
  @@index([drugId])
}
// ======================================================
// PRESCRIPTION
// ======================================================

model Prescription {
  id                 String @id @default(cuid())

  prescriptionNumber String @unique

  patientId          String
  patient            Patient @relation(fields: [patientId], references: [id])

  branchId           String
  branch             Branch @relation(fields: [branchId], references: [id])

  doctorName         String

  diagnosis          String?

  status             PrescriptionStatus @default(PENDING)

  notes              String?

  items              PrescriptionItem[]

  saleId             String?
  sale               Sale? @relation(fields: [saleId], references: [id])

  insuranceClaims    InsuranceClaim[]

  createdAt          DateTime @default(now())

  updatedAt          DateTime @updatedAt

  @@index([patientId])
  @@index([branchId])
  @@index([status])
}
// ======================================================
// PRESCRIPTION ITEM
// ======================================================

model PrescriptionItem {
  id                 String @id @default(cuid())

  prescriptionId     String
  prescription        Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  drugId             String
  drug               Drug @relation(fields: [drugId], references: [id])

  dosage             String

  frequency          String

  duration           String

  quantity           Int

  dispensedQuantity  Int @default(0)

  instructions       String?

  createdAt          DateTime @default(now())

  @@index([prescriptionId])
  @@index([drugId])
}
model InsurancePayer {
  id                     String @id @default(cuid())

  name                   String

  code                   String

  contactEmail           String?

  contactPhone           String?

  preAuthRequired        Boolean @default(false)

  defaultCopayPercent    Decimal @default(0) @db.Decimal(5,2)

  claimPortalUrl         String?

  averageSettlementDays  Int?

  isActive               Boolean @default(true)

  branchId               String
  branch                 Branch @relation(fields: [branchId], references: [id])

  claims                 InsuranceClaim[]

  createdAt              DateTime @default(now())

  updatedAt              DateTime @updatedAt

  deletedAt              DateTime?

  @@unique([branchId, code])

  @@index([branchId])
}

model InsuranceClaim {
  id                      String @id @default(cuid())

  claimNumber             String @unique

  branchId                String
  branch                  Branch @relation(fields: [branchId], references: [id])

  patientId               String
  patient                 Patient @relation(fields: [patientId], references: [id])

  payerId                 String
  payer                   InsurancePayer @relation(fields: [payerId], references: [id])

  saleId                  String?
  sale                    Sale? @relation(fields: [saleId], references: [id])

  prescriptionId          String?
  prescription            Prescription? @relation(fields: [prescriptionId], references: [id])

  policyNumber            String

  memberNumber            String

  principalMemberName     String

  relationshipToPrincipal ClaimantRelationship @default(SELF)

  preAuthStatus           PreAuthStatus @default(NOT_REQUIRED)

  preAuthCode             String?

  claimedAmount           Decimal @db.Decimal(12,2)

  approvedAmount          Decimal? @db.Decimal(12,2)

  copayAmount             Decimal @default(0) @db.Decimal(12,2)

  priority                ClaimPriority @default(NORMAL)

  status                  ClaimStatus @default(DRAFT)

  rejectionReason         String?

  rejectionCode           String?

  submittedAt             DateTime?

  respondedAt             DateTime?

  paidAt                  DateTime?

  paymentReference        String?

  items                   ClaimItem[]

  statusHistory           ClaimStatusHistory[]

  createdById             String

  createdBy               User @relation("ClaimCreatedBy", fields: [createdById], references: [id])

  createdAt               DateTime @default(now())

  updatedAt               DateTime @updatedAt

  deletedAt               DateTime?

  @@index([branchId])

  @@index([patientId])

  @@index([payerId])

  @@index([status])
}

// ======================================================
// CLAIM ITEM
// ======================================================

model ClaimItem {
  id               String @id @default(cuid())

  claimId          String
  claim            InsuranceClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  drugId           String
  drug             Drug @relation(fields: [drugId], references: [id])

  drugName         String

  quantity         Int

  unitPrice        Decimal @db.Decimal(10,2)

  totalAmount      Decimal @db.Decimal(12,2)

  approvedAmount   Decimal? @db.Decimal(12,2)

  rejectionReason  String?

  @@index([claimId])
}

// ======================================================
// CLAIM STATUS HISTORY
// ======================================================

model ClaimStatusHistory {
  id            String @id @default(cuid())

  claimId       String
  claim         InsuranceClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  fromStatus    ClaimStatus?

  toStatus      ClaimStatus

  notes         String?

  changedById   String
  changedBy     User @relation("ClaimStatusChangedBy", fields: [changedById], references: [id])

  createdAt     DateTime @default(now())

  @@index([claimId])
}
// ======================================================
// AUDIT LOG
// ======================================================

model AuditLog {
  id             String @id @default(cuid())

  userId         String?
  user           User? @relation(fields: [userId], references: [id])

  branchId       String?
  branch         Branch? @relation(fields: [branchId], references: [id])

  action         AuditAction

  entity         String

  entityId       String?

  description    String?

  oldValues      Json?

  newValues      Json?

  ipAddress      String?

  userAgent      String?

  createdAt      DateTime @default(now())

  @@index([userId])

  @@index([branchId])

  @@index([entity])

  @@index([createdAt])
}


